# Terraform Variables Configuration
#
# Option 1: Use this file (recommended for persistent config)
#   1. Copy: cp terraform.tfvars.example terraform.tfvars
#   2. Edit terraform.tfvars with your values
#   3. Run: terraform apply
#
# Option 2: Use environment variables (recommended for CI/CD)
#   1. Set TF_VAR_* environment variables (see ../../example.env)
#   2. Run: terraform apply
#   Terraform automatically reads TF_VAR_project_id, TF_VAR_fred_api_key, etc.

# Required: Your GCP project ID
project_id = "your-gcp-project-id"

# Optional: GCP region (default: us-central1)
region = "us-central1"

# Optional: Environment name (default: dev)
environment = "dev"

# Optional: Data retention days (default: 90)
data_retention_days = 90

# Required: FRED API key for economic data
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
fred_api_key = "your-fred-api-key"

# Optional: User agent for SEC API requests
# Should include your contact email
sec_user_agent = "foresight-ml your-email@example.com"

# Optional: List of users authorized to access Airflow
# Format: ["user:email1@example.com", "user:email2@example.com"]
airflow_authorized_users = ["user:your-email@example.com"]

# Optional: Cloud Composer worker machine type (default: e2-standard-2)
composer_machine_type = "e2-standard-2"

# Optional: Cloud Composer environment size
# Allowed: ENVIRONMENT_SIZE_SMALL, ENVIRONMENT_SIZE_MEDIUM, ENVIRONMENT_SIZE_LARGE
composer_environment_size = "ENVIRONMENT_SIZE_SMALL"

# Optional: Enable MLflow tracking infrastructure
enable_mlflow = true

# Required when MLflow is enabled: provide the `TF_VAR_mlflow_db_password`
# environment variable outside this file instead of storing a sample password here.

# Optional: Cloud SQL machine tier for MLflow backend (default: db-custom-1-3840)
mlflow_sql_tier = "db-custom-1-3840"

# Optional: Make MLflow service public for easy SDK access
mlflow_allow_unauthenticated = true

# Required for monitoring alerts: one or more email addresses
alert_emails = ["teammate1@example.com", "teammate2@example.com"]

# Backward-compatible single-email option (prefer alert_emails)
# alert_email = "your-email@example.com"

# Monitoring notifications are currently configured as email-only.

# Optional: create initial secret payload via Terraform
# Set to true only if you want Terraform to write the first secret version.
create_initial_api_keys_version = false

# Optional: API keys payload stored in Secret Manager (JSON map)
# api_keys_secret_payload = {
#   fred_api_key = "your-fred-key"
# }
